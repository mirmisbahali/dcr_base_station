<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    MOBILE BASE — LINKS AND JOINTS
    ==============================
    Defines the physical structure of the rover chassis and wheels.
    Edit this file to change geometry, dimensions, or joint types.

    Layout:
      base_link  ← chassis box (0.7m L x 0.45m W x 0.2m H)
      6 x wheel links  (cylinder r=0.1m, l=0.1m) — continuous joints around Y axis
        Left side:  wheel_front_left, wheel_mid_left, wheel_rear_left
        Right side: wheel_front_right, wheel_mid_right, wheel_rear_right

    Offset conventions:
      Y-offset = chassis_half_width (0.225) + wheel_half_length (0.05) = 0.275m
      Z-offset = -chassis_half_height = -0.1m  (axle flush with chassis bottom)
  -->

  <!-- ==================== CHASSIS ==================== -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.7 0.45 0.2"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <!-- ==================== WHEEL LINKS ==================== -->
  <!-- Visual rotated 90deg around X so the cylinder disk faces outward (Y axis) -->

  <link name="wheel_front_left">
    <visual>
      <geometry><cylinder radius="0.1" length="0.1"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <link name="wheel_mid_left">
    <visual>
      <geometry><cylinder radius="0.1" length="0.1"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <link name="wheel_rear_left">
    <visual>
      <geometry><cylinder radius="0.1" length="0.1"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <link name="wheel_front_right">
    <visual>
      <geometry><cylinder radius="0.1" length="0.1"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <link name="wheel_mid_right">
    <visual>
      <geometry><cylinder radius="0.1" length="0.1"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <link name="wheel_rear_right">
    <visual>
      <geometry><cylinder radius="0.1" length="0.1"/></geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <!-- ==================== WHEEL JOINTS ==================== -->

  <joint name="joint_wheel_front_left" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_left"/>
    <origin xyz="0.25 0.275 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="joint_wheel_mid_left" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_mid_left"/>
    <origin xyz="0.0 0.275 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="joint_wheel_rear_left" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rear_left"/>
    <origin xyz="-0.25 0.275 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="joint_wheel_front_right" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_right"/>
    <origin xyz="0.25 -0.275 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="joint_wheel_mid_right" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_mid_right"/>
    <origin xyz="0.0 -0.275 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="joint_wheel_rear_right" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rear_right"/>
    <origin xyz="-0.25 -0.275 -0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>
